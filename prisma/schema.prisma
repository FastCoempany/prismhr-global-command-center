generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  VIEWER
}

enum CanonStatus {
  CANON
  HYPOTHESIS
  INFERENCE
  UNKNOWN
  UNVERIFIED
}

enum SourceConfidence {
  CONFIRMED
  STRONG
  MEDIUM
  LOW
  UNVERIFIED
  INFERRED
  HYPOTHESIS
}

enum NoteSensitivity {
  PUBLIC_RESEARCH
  INTERNAL_ONLY
  PRIVATE_CSM_DEBRIEF
  SENSITIVE_BOUNDARY
  LEGAL_COMPLIANCE_SENSITIVE
  SHAREABLE_SUMMARY
}

enum PermissionState {
  RESEARCH_ONLY
  CSM_CONTEXT_NEEDED
  CSM_APPROVED_FOR_DISCUSSION
  CSM_APPROVED_FOR_INTRO
  PEO_ENGAGED
  PEO_CLIENT_ENGAGED
  DIRECT_CONTACT_ALLOWED
  DIRECT_CONTACT_NOT_ALLOWED
  HOLD_SENSITIVE
  OFF_LIMITS
  OWNERSHIP_UNCLEAR_REQUIRES_VERIFICATION
}

enum HmlValue {
  HIGH
  MEDIUM
  LOW
}

enum TerritoryAccountStatus {
  RESEARCH_ONLY
  WATCH
  PARKED
  READY_FOR_REVIEW
  CONVERTED_TO_OPPORTUNITY
}

enum ProductRelevance {
  EOR
  CONTRACTOR_MANAGEMENT
  CONTRACTOR_MANAGEMENT_PLUS
  GLOBAL_PAYROLL
  CROSS_BORDER_RECRUITING
}

enum EvidenceType {
  PUBLIC_WEB
  COMPANY_SITE
  JOB_POSTING
  LINKEDIN
  NEWS
  MANUAL_RESEARCH
  INTERNAL_NOTE
  USER_ASSERTION
}

enum NoteType {
  RESEARCH_NOTE
  FIT_SIGNAL
  BOUNDARY_NOTE
  PRIVATE_DEBRIEF
  SHAREABLE_SUMMARY
}

enum UnknownCategory {
  SCHEMA
  PERMISSION
  HML
  DATA_VISIBILITY
  PRODUCT
  PRICING_LEGAL
  EXTERNAL_CHANNEL
  TERRITORY
  SOURCE_EVIDENCE
}

enum InternalUnknownStatus {
  OPEN
  DEFERRED
  DECIDED
  NO_LONGER_RELEVANT
}

enum HmlCategory {
  TERRITORY_ACCOUNT_POTENTIAL
  BOUNDARY_RISK
  SOURCE_CONFIDENCE
  INTERNAL_AMBIGUITY
  CSM_RELATIONSHIP_HEAT
  PEO_READINESS
  PEO_PROTECTIVENESS
  OPPORTUNITY_MOMENTUM
  FOLLOW_UP_URGENCY
}

enum CsmPartnerStatus {
  ACTIVE
  WATCH
  PARKED
}

enum OpportunitySourceType {
  CSM
  PEO
  PEO_CLIENT
  TERRITORY_ACCOUNT
  EXTERNAL_CHANNEL
  MANUAL_RESEARCH
}

enum OpportunityStage {
  RESEARCH
  CSM_CONTEXT_NEEDED
  QUALIFYING
  INTRO_READY
  MEETING_BOOKED
  ACTIVE_DISCOVERY
  PARKED
  CLOSED_WON
  CLOSED_LOST
}

enum FollowUpPromiseStatus {
  OPEN
  DEFERRED
  COMPLETED
  CANCELLED
}

enum ApprovalStatus {
  DRAFT
  NEEDS_OWNER_REVIEW
  OWNER_APPROVED
  RETIRED
}

enum PitchAudience {
  CSM
  PEO
  PEO_CLIENT
  INTERNAL
  EXTERNAL_CHANNEL
}

enum PitchAssetType {
  CSM_SAFE_BLURB
  DISCOVERY_CHEAT_SHEET
  OBJECTION_RESPONSE
  EMAIL_LANGUAGE
  MEETING_PREP_NOTE
  USE_CASE_BRIEF
}

enum DailyServeCategory {
  PEO_TALKING_POINT
  CLIENT_FIT_SIGNAL
  PRODUCT_EXPLAINER
  USE_CASE_BLURB
  DISCOVERY_QUESTION
  COMPLIANCE_WATCHOUT
  OBJECTION_RESPONSE
  MEETING_PREP
  FOLLOW_UP_LANGUAGE
}

enum DailyServeStatus {
  DRAFT
  READY
  SENT
  HELD
  ARCHIVED
}

enum DailyServeOutcome {
  PENDING
  USED_BY_CSM
  FORWARDED
  REPLIED
  CREATED_NEXT_STEP
  CONVERTED_TO_OPPORTUNITY
  NO_RESPONSE
  NOT_USEFUL
}

enum BoundaryScopeType {
  CSM_PARTNER
  PEO
  PEO_CLIENT
  OPPORTUNITY
  TERRITORY_ACCOUNT
  EXTERNAL_CHANNEL
  GLOBAL
}

enum BoundaryRuleType {
  OFF_LIMITS
  APPROVAL_REQUIRED
  HOLD_SENSITIVE
  DIRECT_CONTACT_NOT_ALLOWED
  RELATIONSHIP_OWNER_REQUIRED
  ALLOWED_ALTERNATIVE
}

enum BoundarySeverity {
  WARNING
  APPROVAL_REQUIRED
  BLOCKED
}

enum BoundaryRuleStatus {
  ACTIVE
  EXPIRED
  SUPERSEDED
  REVOKED
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  role           UserRole  @default(VIEWER)
  isActive       Boolean   @default(false)
  isProductOwner Boolean   @default(false)
  isCanonOwner   Boolean   @default(false)
  lastSignedInAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  territoryAccounts TerritoryAccount[]
  csmPartners       CSMPartner[]
  followUpPromises  FollowUpPromise[]
  dailyServes       DailyServe[]
}

model TerritoryAccount {
  id                  String                 @id @default(cuid())
  companyName         String
  website             String?
  city                String                 @default("Chicago")
  region              String                 @default("Chicagoland")
  category            String?
  status              TerritoryAccountStatus @default(RESEARCH_ONLY)
  productRelevance    ProductRelevance[]
  internationalSignal HmlValue               @default(LOW)
  contractorSignal    HmlValue               @default(LOW)
  hiringSignal        HmlValue               @default(LOW)
  complexitySignal    HmlValue               @default(LOW)
  channelSignal       HmlValue               @default(LOW)
  boundaryRisk        HmlValue               @default(LOW)
  priorityScore       Int?
  fitSummary          String
  nextSafestAction    String
  permissionState     PermissionState        @default(RESEARCH_ONLY)
  sourceConfidence    SourceConfidence       @default(UNVERIFIED)
  canonStatus         CanonStatus            @default(UNVERIFIED)
  ownerId             String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  lastReviewedAt      DateTime?

  owner              User?               @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  evidence           SourceEvidence[]
  notes              Note[]
  permissionHistory  PermissionHistory[]
  internalUnknowns   InternalUnknown[]
  hmlClassifications HmlClassification[]
  opportunities      Opportunity[]
  followUpPromises   FollowUpPromise[]
  boundaryRules      BoundaryRule[]
  dailyServes        DailyServe[]

  @@index([companyName])
  @@index([status])
  @@index([permissionState])
  @@index([sourceConfidence])
}

model SourceEvidence {
  id            String           @id @default(cuid())
  accountId     String
  type          EvidenceType     @default(PUBLIC_WEB)
  title         String
  url           String?
  capturedClaim String
  sourceDate    DateTime?
  staleAfter    DateTime?
  confidence    SourceConfidence @default(UNVERIFIED)
  canonStatus   CanonStatus      @default(UNVERIFIED)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  account TerritoryAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([confidence])
}

model Note {
  id               String           @id @default(cuid())
  accountId        String?
  csmPartnerId     String?
  peoId            String?
  opportunityId    String?
  noteType         NoteType         @default(RESEARCH_NOTE)
  body             String
  sensitivity      NoteSensitivity  @default(INTERNAL_ONLY)
  sourceConfidence SourceConfidence @default(UNVERIFIED)
  shareability     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  account     TerritoryAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  csmPartner  CSMPartner?       @relation(fields: [csmPartnerId], references: [id], onDelete: SetNull)
  peo         PEO?              @relation(fields: [peoId], references: [id], onDelete: SetNull)
  opportunity Opportunity?      @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([csmPartnerId])
  @@index([peoId])
  @@index([opportunityId])
  @@index([sensitivity])
}

model PermissionHistory {
  id        String          @id @default(cuid())
  accountId String
  state     PermissionState
  reason    String
  setBy     String?
  createdAt DateTime        @default(now())

  account TerritoryAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([state])
}

model InternalUnknown {
  id                   String                @id @default(cuid())
  question             String
  category             UnknownCategory
  currentBestAnswer    String?
  sourceNeeded         String?
  confidence           SourceConfidence      @default(UNVERIFIED)
  riskLevel            HmlValue              @default(MEDIUM)
  status               InternalUnknownStatus @default(OPEN)
  blocksImplementation Boolean               @default(false)
  relatedAccountId     String?
  csmPartnerId         String?
  peoId                String?
  opportunityId        String?
  dailyServeId         String?
  dueAt                DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  relatedAccount     TerritoryAccount?   @relation(fields: [relatedAccountId], references: [id], onDelete: SetNull)
  csmPartner         CSMPartner?         @relation(fields: [csmPartnerId], references: [id], onDelete: SetNull)
  peo                PEO?                @relation(fields: [peoId], references: [id], onDelete: SetNull)
  opportunity        Opportunity?        @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  dailyServe         DailyServe?         @relation(fields: [dailyServeId], references: [id], onDelete: SetNull)
  hmlClassifications HmlClassification[]

  @@index([category])
  @@index([status])
  @@index([relatedAccountId])
  @@index([csmPartnerId])
  @@index([peoId])
  @@index([opportunityId])
  @@index([dailyServeId])
}

model CSMPartner {
  id                      String           @id @default(cuid())
  name                    String
  email                   String?          @unique
  status                  CsmPartnerStatus @default(ACTIVE)
  relationshipHeat        HmlValue         @default(MEDIUM)
  protectivenessLevel     HmlValue         @default(MEDIUM)
  communicationCadence    String?
  preferredIntroMotion    String?
  preferredFollowupMotion String?
  privateDebriefRequired  Boolean          @default(true)
  dosAndDonts             String?
  trustSurfaceNotes       String?
  permissionState         PermissionState  @default(CSM_CONTEXT_NEEDED)
  sourceConfidence        SourceConfidence @default(UNVERIFIED)
  canonStatus             CanonStatus      @default(HYPOTHESIS)
  nextSafestAction        String
  ownerId                 String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  lastReviewedAt          DateTime?

  owner              User?               @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  peos               PEO[]
  opportunities      Opportunity[]
  notes              Note[]
  followUpPromises   FollowUpPromise[]
  hmlClassifications HmlClassification[]
  boundaryRules      BoundaryRule[]
  dailyServes        DailyServe[]
  internalUnknowns   InternalUnknown[]

  @@index([name])
  @@index([status])
  @@index([permissionState])
  @@index([relationshipHeat])
}

model PEO {
  id                    String           @id @default(cuid())
  name                  String
  website               String?
  csmPartnerId          String?
  publicResearchSummary String?
  industryFocus         String?
  clientBaseNotes       String?
  globalFitSignals      String?
  readinessLevel        HmlValue         @default(MEDIUM)
  protectivenessLevel   HmlValue         @default(MEDIUM)
  boundaryRisk          HmlValue         @default(MEDIUM)
  permissionState       PermissionState  @default(CSM_CONTEXT_NEEDED)
  sourceConfidence      SourceConfidence @default(UNVERIFIED)
  canonStatus           CanonStatus      @default(HYPOTHESIS)
  offLimitsSummary      String?
  nextSafestAction      String
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  lastReviewedAt        DateTime?

  csmPartner         CSMPartner?         @relation(fields: [csmPartnerId], references: [id], onDelete: SetNull)
  peoClients         PEOClient[]
  opportunities      Opportunity[]
  notes              Note[]
  followUpPromises   FollowUpPromise[]
  hmlClassifications HmlClassification[]
  boundaryRules      BoundaryRule[]
  dailyServes        DailyServe[]
  internalUnknowns   InternalUnknown[]

  @@index([name])
  @@index([csmPartnerId])
  @@index([permissionState])
  @@index([readinessLevel])
  @@index([protectivenessLevel])
}

model PEOClient {
  id               String           @id @default(cuid())
  displayName      String
  peoId            String
  industry         String?
  countries        String[]         @default([])
  workerTypes      String[]         @default([])
  useCaseFit       String?
  permissionState  PermissionState  @default(CSM_CONTEXT_NEEDED)
  sourceConfidence SourceConfidence @default(UNVERIFIED)
  boundaryRisk     HmlValue         @default(MEDIUM)
  noteSensitivity  NoteSensitivity  @default(INTERNAL_ONLY)
  isAnonymized     Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  peo           PEO            @relation(fields: [peoId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]
  boundaryRules BoundaryRule[]

  @@index([peoId])
  @@index([permissionState])
  @@index([boundaryRisk])
}

model Opportunity {
  id                   String                @id @default(cuid())
  name                 String
  sourceType           OpportunitySourceType @default(MANUAL_RESEARCH)
  csmPartnerId         String?
  peoId                String?
  peoClientId          String?
  territoryAccountId   String?
  productInterest      ProductRelevance[]    @default([])
  stage                OpportunityStage      @default(RESEARCH)
  nextStep             String
  nextStepOwner        String?
  followUpDueAt        DateTime?
  permissionState      PermissionState       @default(CSM_CONTEXT_NEEDED)
  momentumLevel        HmlValue              @default(MEDIUM)
  riskFlags            String[]              @default([])
  sourceConfidence     SourceConfidence      @default(UNVERIFIED)
  canonStatus          CanonStatus           @default(HYPOTHESIS)
  discoveryFrameworkId String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  csmPartner         CSMPartner?         @relation(fields: [csmPartnerId], references: [id], onDelete: SetNull)
  peo                PEO?                @relation(fields: [peoId], references: [id], onDelete: SetNull)
  peoClient          PEOClient?          @relation(fields: [peoClientId], references: [id], onDelete: SetNull)
  territoryAccount   TerritoryAccount?   @relation(fields: [territoryAccountId], references: [id], onDelete: SetNull)
  discoveryFramework DiscoveryFramework? @relation(fields: [discoveryFrameworkId], references: [id], onDelete: SetNull)
  notes              Note[]
  followUpPromises   FollowUpPromise[]
  hmlClassifications HmlClassification[]
  boundaryRules      BoundaryRule[]
  dailyServes        DailyServe[]
  internalUnknowns   InternalUnknown[]

  @@index([stage])
  @@index([csmPartnerId])
  @@index([peoId])
  @@index([peoClientId])
  @@index([territoryAccountId])
  @@index([discoveryFrameworkId])
  @@index([permissionState])
  @@index([momentumLevel])
}

model FollowUpPromise {
  id                 String                @id @default(cuid())
  promise            String
  madeTo             String
  ownerId            String?
  csmPartnerId       String?
  peoId              String?
  opportunityId      String?
  territoryAccountId String?
  dueAt              DateTime
  status             FollowUpPromiseStatus @default(OPEN)
  sensitivity        NoteSensitivity       @default(INTERNAL_ONLY)
  sourceConfidence   SourceConfidence      @default(UNVERIFIED)
  overdueAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  owner            User?             @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  csmPartner       CSMPartner?       @relation(fields: [csmPartnerId], references: [id], onDelete: SetNull)
  peo              PEO?              @relation(fields: [peoId], references: [id], onDelete: SetNull)
  opportunity      Opportunity?      @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  territoryAccount TerritoryAccount? @relation(fields: [territoryAccountId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([csmPartnerId])
  @@index([peoId])
  @@index([opportunityId])
  @@index([territoryAccountId])
  @@index([status])
  @@index([dueAt])
}

model BoundaryRule {
  id                 String             @id @default(cuid())
  scopeType          BoundaryScopeType
  csmPartnerId       String?
  peoId              String?
  peoClientId        String?
  opportunityId      String?
  territoryAccountId String?
  ruleType           BoundaryRuleType
  title              String
  description        String
  setBy              String?
  reason             String
  effectiveFrom      DateTime           @default(now())
  expiresAt          DateTime?
  reviewAt           DateTime?
  severity           BoundarySeverity   @default(APPROVAL_REQUIRED)
  allowedAlternative String?
  status             BoundaryRuleStatus @default(ACTIVE)
  sourceConfidence   SourceConfidence   @default(UNVERIFIED)
  canonStatus        CanonStatus        @default(HYPOTHESIS)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  csmPartner       CSMPartner?       @relation(fields: [csmPartnerId], references: [id], onDelete: SetNull)
  peo              PEO?              @relation(fields: [peoId], references: [id], onDelete: SetNull)
  peoClient        PEOClient?        @relation(fields: [peoClientId], references: [id], onDelete: SetNull)
  opportunity      Opportunity?      @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  territoryAccount TerritoryAccount? @relation(fields: [territoryAccountId], references: [id], onDelete: SetNull)

  @@index([scopeType])
  @@index([ruleType])
  @@index([severity])
  @@index([status])
  @@index([reviewAt])
  @@index([csmPartnerId])
  @@index([peoId])
  @@index([peoClientId])
  @@index([opportunityId])
  @@index([territoryAccountId])
}

model DiscoveryFramework {
  id                      String           @id @default(cuid())
  title                   String
  productRelevance        ProductRelevance
  audience                PitchAudience    @default(CSM)
  useCase                 String
  triggerSignals          String[]         @default([])
  discoveryQuestions      String[]         @default([])
  disqualificationSignals String[]         @default([])
  demoFocus               String?
  boundaryNotes           String?
  sourceConfidence        SourceConfidence @default(UNVERIFIED)
  canonStatus             CanonStatus      @default(HYPOTHESIS)
  approvalStatus          ApprovalStatus   @default(DRAFT)
  approvedBy              String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  opportunities Opportunity[]

  @@index([productRelevance])
  @@index([audience])
  @@index([approvalStatus])
  @@index([sourceConfidence])
}

model PitchAsset {
  id               String           @id @default(cuid())
  title            String
  productRelevance ProductRelevance
  assetType        PitchAssetType
  audience         PitchAudience    @default(CSM)
  content          String
  usageNotes       String?
  sourceConfidence SourceConfidence @default(UNVERIFIED)
  canonStatus      CanonStatus      @default(HYPOTHESIS)
  approvalStatus   ApprovalStatus   @default(DRAFT)
  approvedBy       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  dailyServes DailyServe[]

  @@index([productRelevance])
  @@index([assetType])
  @@index([audience])
  @@index([approvalStatus])
  @@index([sourceConfidence])
}

model DailyServe {
  id                 String             @id @default(cuid())
  title              String
  category           DailyServeCategory
  status             DailyServeStatus   @default(DRAFT)
  outcome            DailyServeOutcome  @default(PENDING)
  content            String
  usefulnessReason   String
  nextSafestAction   String
  ownerId            String?
  csmPartnerId       String?
  peoId              String?
  opportunityId      String?
  territoryAccountId String?
  pitchAssetId       String?
  sourceConfidence   SourceConfidence   @default(UNVERIFIED)
  canonStatus        CanonStatus        @default(HYPOTHESIS)
  relationshipImpact HmlValue           @default(MEDIUM)
  opportunityImpact  HmlValue           @default(MEDIUM)
  sentAt             DateTime?
  outcomeAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  owner              User?               @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  csmPartner         CSMPartner?         @relation(fields: [csmPartnerId], references: [id], onDelete: SetNull)
  peo                PEO?                @relation(fields: [peoId], references: [id], onDelete: SetNull)
  opportunity        Opportunity?        @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  territoryAccount   TerritoryAccount?   @relation(fields: [territoryAccountId], references: [id], onDelete: SetNull)
  pitchAsset         PitchAsset?         @relation(fields: [pitchAssetId], references: [id], onDelete: SetNull)
  hmlClassifications HmlClassification[]
  internalUnknowns   InternalUnknown[]

  @@index([ownerId])
  @@index([csmPartnerId])
  @@index([peoId])
  @@index([opportunityId])
  @@index([territoryAccountId])
  @@index([pitchAssetId])
  @@index([category])
  @@index([status])
  @@index([outcome])
  @@index([sentAt])
  @@index([outcomeAt])
}

model HmlClassification {
  id                    String           @id @default(cuid())
  category              HmlCategory
  accountId             String?
  csmPartnerId          String?
  peoId                 String?
  opportunityId         String?
  dailyServeId          String?
  internalUnknownId     String?
  classification        HmlValue
  confidence            SourceConfidence
  explanation           String
  contributingSignals   String[]
  recommendedNextAction String
  ruleVersion           String           @default("v0.1")
  createdAt             DateTime         @default(now())

  account         TerritoryAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  csmPartner      CSMPartner?       @relation(fields: [csmPartnerId], references: [id], onDelete: Cascade)
  peo             PEO?              @relation(fields: [peoId], references: [id], onDelete: Cascade)
  opportunity     Opportunity?      @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  dailyServe      DailyServe?       @relation(fields: [dailyServeId], references: [id], onDelete: SetNull)
  internalUnknown InternalUnknown?  @relation(fields: [internalUnknownId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([accountId])
  @@index([csmPartnerId])
  @@index([peoId])
  @@index([opportunityId])
  @@index([dailyServeId])
  @@index([internalUnknownId])
  @@index([classification])
}

// --- Demo Sidekick -----------------------------------------------------------
// Account-based demo companion. Catalog screens live in the app bundle
// (src/lib/catalog); only per-account mutable state is persisted here.

enum DemoAudience {
  BOTH
  SERVICE_PROVIDER
  DIRECT_EMPLOYER
}

model DemoAccount {
  id              String       @id @default(cuid())
  name            String
  company         String?
  personaLabel    String?
  defaultAudience DemoAudience @default(BOTH)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  notes     DemoNote[]
  pins      DemoPin[]
  playbooks DemoPlaybook[]

  @@index([name])
}

model DemoNote {
  id        String   @id @default(cuid())
  accountId String
  screenId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account DemoAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, screenId])
  @@index([accountId])
}

model DemoPin {
  id        String   @id @default(cuid())
  accountId String
  screenId  String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  account DemoAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, screenId])
  @@index([accountId])
}

model DemoPlaybook {
  id        String   @id @default(cuid())
  accountId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account DemoAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  items   DemoPlaybookItem[]

  @@index([accountId])
}

model DemoPlaybookItem {
  id         String   @id @default(cuid())
  playbookId String
  screenId   String
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  playbook DemoPlaybook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@index([playbookId])
}

// Global, editable script overrides layered over the static catalog. A null
// scalar or empty array means "fall back to the catalog value" for that field.
model DemoScreenOverride {
  id           String   @id @default(cuid())
  screenId     String   @unique
  say          String?
  what         String?
  capabilities String[]
  sp           String[]
  de           String[]
  branching    String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// --- Command Center (rebuilt) ------------------------------------------------
// The PEO "book" itself is static (src/lib/book). Only the mutable per-PEO
// working state lives here, keyed by the Salesforce account id.

enum PeoStage {
  NOT_TOUCHED
  CSM_BRIEFED
  PEO_ENGAGED
  CLIENT_CAMPAIGN
  LEAD
  DEMO
  OPPORTUNITY
  WON
  PASSED
}

// Channel permission gate — what you're allowed to do with this PEO right now.
// Enforces the go-to-market motion: reach the SMB *through* its PEO, and only
// after the CSM has cleared the path.
enum PeoApproach {
  NEEDS_CSM // prep only — don't approach the PEO until the CSM clears it
  CHANNEL_OK // CSM has cleared it — work the PEO directly
  DIRECT_OK // PEO engaged — cleared to approach their SMB clients
}

// Intent signal: how much international-hiring demand sits in the PEO's book.
// Layered on top of the structural fit score to re-rank toward real demand.
enum PeoIntent {
  UNKNOWN
  LOW
  MEDIUM
  HIGH
}

model PeoState {
  id             String      @id @default(cuid())
  peoId          String      @unique // Salesforce 18-digit id from the book
  stage          PeoStage    @default(NOT_TOUCHED)
  approach       PeoApproach @default(NEEDS_CSM)
  intent         PeoIntent   @default(UNKNOWN)
  nextAction     String?
  nextActionDate DateTime?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  activities PeoActivity[]

  @@index([stage])
  @@index([approach])
  @@index([nextActionDate])
}

model PeoActivity {
  id        String   @id @default(cuid())
  peoId     String
  body      String
  createdAt DateTime @default(now())

  state PeoState @relation(fields: [peoId], references: [peoId], onDelete: Cascade)

  @@index([peoId])
}

// --- Dashboard (moonshot) ----------------------------------------------------
// A hand-sewn, fully manual board. Deliberately isolated: it derives nothing
// from PeoState / the book / anything else. Every card and node state is set by
// hand. `states` / `notes` are JSON maps keyed by dashboard node key.
model DashCard {
  id         String   @id @default(cuid())
  name       String
  subtitle   String?
  position   Int      @default(0)
  archived   Boolean  @default(false)
  states     Json? // { nodeKey: "todo"|"active"|"done" }
  notes      Json? // { nodeKey: string }  (general per-node note, e.g. research seed)
  checks     Json? // { nodeKey: boolean[] }  (mandatory checkbox state)
  checkNotes Json? // { nodeKey: { itemIndex: string } }  (per-checkbox note)
  activated    Json? // { nodeKey: isoString }  (when a node first went active — ages commitments)
  dealSize     String? // free-text estimated size ("$120k ARR", "300 EEs / 4 countries")
  stakeholders Json? // [{ name, role, note }]  (people on the deal, each its own box)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([position])
  @@index([archived])
}

// Singleton (id = "default") holding the dashboard's editable stage-column
// labels. Still fully manual — just lets the labels be renamed in-browser.
model DashConfig {
  id        String   @id
  labels    Json?
  updatedAt DateTime @updatedAt
}

// --- Field notes -------------------------------------------------------------
// The owner's running "voice of the base" + enablement-gap capture. Standalone
// (not tied to any account): what we have, what we don't, what we need to arm
// partners like Eric — the raw material carried into the Aleks 1:1 and to
// marketing. Deliberately simple: a kind, a body, a resolved flag.
//   kind: "gap"   — an enablement gap ("we have no country one-pager for Brazil")
//         "voice" — a voice-of-the-base observation ("3rd account this month
//                   asking about contractor conversion")
//         "ask"   — something needed from Aleks / marketing / product
model FieldNote {
  id        String   @id @default(cuid())
  kind      String   @default("gap")
  body      String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
  @@index([resolved])
}

// Completion marks for the day/week — so the owner can see when every little
// task is done. The key encodes the task AND its period (e.g.
// "morning:2026-07-06:acct:<id>" or "kickoff:2026-W28:Anika Steenstra"), so it
// resets automatically on a new day/week. Presence = done.
model TaskDone {
  id     String   @id @default(cuid())
  key    String   @unique
  doneAt DateTime @default(now())

  @@index([key])
}

// --- Today interaction overlays ---------------------------------------------
// Small, isolated stores that let Today become act-in-place without duplicating
// the Dashboard ledger. Keyed by the Salesforce account id from the book.

// A deliberately parked signal — "not now, here's why". Resurfaces when
// snoozedUntil passes (null = parked until manually un-parked).
model SignalSnooze {
  id           String    @id @default(cuid())
  accountId    String    @unique
  reason       String
  snoozedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([accountId])
}

// Owner/CSM validation of an AI-researched score — the trust layer that keeps
// the app from bossing you around on unverified data. status:
//   "confirmed" — sanity-checked, the score stands
//   "flagged"   — looks wrong (note says why); score is visibly distrusted
//   "adjusted"  — demand overridden to adjustedDemand; flows into the composite
model ScoreValidation {
  id             String   @id @default(cuid())
  accountId      String   @unique
  status         String   @default("confirmed")
  adjustedDemand Int?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([accountId])
}

// Resolution state for a curated Look-into item (keyed by its static id).
model LookIntoStatus {
  id        String   @id @default(cuid())
  itemId    String   @unique
  resolved  Boolean  @default(false)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId])
}

// A logged contact ("touch") with an automatic follow-up cadence. Marking a
// partner contacted (or an outreach sent) creates one; Today then surfaces it
// when the follow-up comes due and keeps nudging every `intervalDays` until you
// mark a reply. `subjectKey` is stable and deterministic (e.g.
// "kickoff:2026-W28:Anika Steenstra" or "outreach:<accountId>") so re-contacting
// the same subject advances the same thread instead of duplicating it. label /
// detail snapshot the display text so the follow-up list is self-contained.
model Touch {
  id           String   @id @default(cuid())
  subjectKey   String   @unique
  kind         String   @default("partner") // "partner" | "account"
  label        String
  detail       String?
  message      String? // what was said — the opener you actually sent
  contactedAt  DateTime @default(now())
  followUpAt   DateTime // when the next check-in is due
  intervalDays Int      @default(2)
  status       String   @default("awaiting") // "awaiting" | "replied"
  log          Json? // [{ at: isoString, body: string }] — follow-up notes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([followUpAt])
}

// A note / to-do — the right-hand column beside Follow-ups on Today, upgraded
// into a live notetaker (autosaved as you type). Optionally tied to an account
// and given a date/time. No cadence — just your running notes.
model Todo {
  id        String    @id @default(cuid())
  body      String
  done      Boolean   @default(false)
  accountId String? // optional link to a book account (Salesforce id)
  remindAt  DateTime? // optional date/time set via the calendar picker
  position  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([done])
  @@index([position])
  @@index([accountId])
}

// Stash — the app-wide capture inbox. Any text you highlight, right-click, or
// drag from any tab lands here as a captured item with an auto micro-note. From
// the tray you route it to a lane: "todo" → Todo (Notetaker), "follow" → Touch
// (Follow-ups), "gap" → FieldNote (Voice of the base). Right-click routing goes
// straight to the lane and never creates a StashItem; only un-routed grabs
// (highlight / drag) persist here until sorted. Isolated + additive: routing
// writes to the existing stores, so nothing here couples to them at read time.
model StashItem {
  id        String   @id @default(cuid())
  body      String // the raw captured text
  micro     String   @default("") // deterministic one-line summary (Sharpen can rewrite it)
  source    String   @default("") // where it came from, e.g. "selection" or "Accounts › Meridian HR"
  accountId String? // optional book account (Salesforce id) when captured from one
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

// A dated, time-stamped note pinned to a book ACCOUNT from the partner-outreach
// chips on Today: either your own note ("mine") or what the partner told you
// about it ("partner"). Surfaces on the Account Room's detail panel — NOT in the
// Notes/Follow-ups tabs. Also drives the chip freshness color (green/yellow/red
// by time since the account was last touched).
model AccountNote {
  id        String   @id @default(cuid())
  accountId String // book account (Salesforce id)
  partner   String   @default("") // whose outreach card it was written from
  kind      String   @default("mine") // "mine" | "partner"
  body      String
  createdAt DateTime @default(now())

  @@index([accountId, createdAt])
}

// A dated, time-stamped note pinned to a partner (CSM) — the by-partner
// repository behind the Partner Room and the notes strip on each partner's
// outreach card. Written from Stash routing, the Partner Room's note box, or
// anywhere else that talks about a partner. Keyed by the partner's name (the
// same string the book's `csm` field uses).
model PartnerNote {
  id        String   @id @default(cuid())
  partner   String
  body      String
  source    String   @default("") // e.g. "stash", "partner-room", "today"
  createdAt DateTime @default(now())

  @@index([partner, createdAt])
}

// Per-account engagement — the CSM's meeting cadence with the client, a running
// CSM-notes/health read, and whether Salesforce research has been pulled. Keyed
// by the Salesforce account id from the book (like SignalSnooze / ScoreValidation).
model AccountEngagement {
  id            String    @id @default(cuid())
  accountId     String    @unique
  cadence       String?
  meetingDay    String?
  nextMeetingAt DateTime?
  clientHealth  String? // "green" | "yellow" | "red"
  csmNotes      String?
  sfCheckedAt   DateTime? // when Salesforce research was last pulled
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([accountId])
}

// Off-structure account dispositions — how real life overrides the structured
// research → roundup → reply path. Keyed by the book account id.
//   "motion"   — the conversation is already live (skip the roundup, keep visible)
//   "not-mine" — belongs to another rep; excluded everywhere, kept in the
//                Account Room's exclusions ledger with the reason
//   "parked"   — deliberately shelved for now (dimmed, out of the roundup)
model AccountDisposition {
  id        String   @id @default(cuid())
  accountId String   @unique
  status    String // "motion" | "not-mine" | "parked"
  reason    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}
