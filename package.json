{
  "name": "prismhr-global-command-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "prisma generate && tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check \"*.{json,ts,mjs}\" \"src/**/*.{ts,tsx,css}\" \"prisma/**/*.ts\" \"config/**/*.{css,yaml,yml}\"",
    "format": "prettier --write \"*.{json,ts,mjs}\" \"src/**/*.{ts,tsx,css}\" \"prisma/**/*.ts\" \"config/**/*.{css,yaml,yml}\"",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@tailwindcss/postcss": "4.3.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "prettier": "3.8.4",
    "prisma": "7.8.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
